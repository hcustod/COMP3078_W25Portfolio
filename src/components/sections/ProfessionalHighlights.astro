---
import SectionHeading from './SectionHeading.astro';
import { professionalSamples } from '../../data/site';

interface Props {
  eyebrow?: string;
  title?: string;
  intro?: string;
  sectionId?: string;
}

const {
  eyebrow = 'Professional summary',
  title = 'Work samples',
  intro = 'Three concise professional snapshots that emphasize delivery, reliability, and operational depth.',
  sectionId,
} = Astro.props;
---
<section class="section-shell shell" id={sectionId}>
  <SectionHeading
    eyebrow={eyebrow}
    title={title}
    intro={intro}
  />
  <div class="card-grid card-grid-wide">
    {professionalSamples.map((sample) => (
      <article class="glass-card" data-reveal>
        <p class="section-eyebrow">{sample.organization}</p>
        <h3>{sample.title}</h3>
        <p>{sample.summary}</p>
        <ul class="bullet-list compact">
          {sample.outcomes.map((outcome) => <li>{outcome}</li>)}
        </ul>
        <div class="tech-row">
          {sample.tools.map((tool) => <span class="tag-chip">{tool}</span>)}
        </div>
      </article>
    ))}
  </div>
</section>
