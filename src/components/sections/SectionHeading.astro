---
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  align?: 'left' | 'center';
}

const {
  eyebrow,
  title,
  intro,
  align = 'left',
} = Astro.props;
---
<div class:list={['section-heading', align === 'center' && 'section-heading-center']} data-reveal>
  {eyebrow && <p class="section-eyebrow">{eyebrow}</p>}
  <h2>{title}</h2>
  {intro && <p class="section-intro">{intro}</p>}
</div>
