---
import BaseLayout from '../components/layout/BaseLayout.astro';
import DocumentList from '../components/sections/DocumentList.astro';
import SectionHeading from '../components/sections/SectionHeading.astro';
import { documents } from '../data/site';

const currentPath = Astro.url.pathname;
const availableDocuments = documents;
---
<BaseLayout
  currentPath={currentPath}
  title="Documents | Henrique Custodio"
  description="Centralized resume, writing samples, academic summary, and capstone outline downloads."
>
  <section class="section-shell shell page-hero">
    <SectionHeading
      eyebrow="Documents"
      title="Selected documents and downloads"
      intro="This page centralizes the supporting materials that sit alongside the portfolio itself."
    />
    <div class="toolbar-actions" data-reveal>
      <a class="button-secondary" href="/about/#documents">Open the integrated About page</a>
    </div>
    <div class="two-column-grid">
      <article class="glass-card" data-reveal>
        <h3>Included here</h3>
        <ul class="bullet-list compact">
          <li>Resume and personal writing samples</li>
          <li>Academic credentials summary</li>
          <li>Capstone outline</li>
        </ul>
      </article>
      <article class="glass-card" data-reveal>
        <h3>Use this page for</h3>
        <ul class="bullet-list compact">
          <li>Quick recruiter review</li>
          <li>Downloadable supporting context</li>
          <li>Easy access to written portfolio materials</li>
        </ul>
      </article>
    </div>
  </section>

  <DocumentList
    title="Available downloads"
    intro="A compact document set with the core portfolio materials kept easy to open."
    items={availableDocuments}
  />
</BaseLayout>
