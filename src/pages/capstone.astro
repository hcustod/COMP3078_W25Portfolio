---
import BaseLayout from '../components/layout/BaseLayout.astro';
import SectionHeading from '../components/sections/SectionHeading.astro';
import Icon from '../components/ui/Icon.astro';
import { capstone } from '../data/capstone';

const currentPath = Astro.url.pathname;
const anchors = [
  { id: 'summary', label: 'Summary' },
  { id: 'vision', label: 'Vision' },
  { id: 'requirements', label: 'Requirements' },
  { id: 'plan', label: 'Plan' },
  { id: 'analysis-design', label: 'Analysis & Design' },
  { id: 'wireframes', label: 'Wireframes' },
  { id: 'status-reports', label: 'Status Reports' },
  { id: 'implementation', label: 'Implementation' },
];
---
<BaseLayout
  currentPath={currentPath}
  title="Capstone | Henrique Custodio"
  description="Capstone hub with summary, vision, business requirements, plan, analysis and design, wireframes, status reports, and implementation notes."
>
  <section class="section-shell shell page-hero">
    <SectionHeading
      eyebrow="Capstone hub"
      title={capstone.projectTitle}
      intro={capstone.statusNote}
    />
    <div class="toolbar-actions" data-reveal>
      <a class="button-secondary" href="/academic-projects/#capstone">Open the integrated Work page</a>
    </div>
    <div class="anchor-nav" data-reveal>
      {anchors.map((anchor) => (
        <a class="filter-chip" href={`#${anchor.id}`}>{anchor.label}</a>
      ))}
    </div>
  </section>

  <section class="section-shell shell">
    <div class="card-grid">
      {capstone.artifacts.map((artifact) => (
        <article class="glass-card compact-card" data-reveal>
          <div class="card-topline">
            <p class="section-eyebrow">Resource</p>
          </div>
          <h3>{artifact.label}</h3>
          <p>{artifact.detail}</p>
          <a class="button-secondary" href={artifact.href}>
            <Icon name="arrow" class="h-4 w-4" />
            <span>Open</span>
          </a>
        </article>
      ))}
    </div>
  </section>

  <section class="section-shell shell capstone-stack">
    <article class="glass-card" id="summary" data-reveal>
      <p class="section-eyebrow">Project summary</p>
      <p>{capstone.summary}</p>
    </article>

    <article class="glass-card" id="vision" data-reveal>
      <p class="section-eyebrow">Project vision</p>
      <p>{capstone.vision}</p>
    </article>

    <article class="glass-card" id="requirements" data-reveal>
      <p class="section-eyebrow">Project / business requirements</p>
      <ul class="bullet-list">
        {capstone.businessRequirements.map((requirement) => <li>{requirement}</li>)}
      </ul>
    </article>

    <article class="glass-card" id="plan" data-reveal>
      <p class="section-eyebrow">Project plan</p>
      <div class="stack-grid">
        {capstone.projectPlan.map((step) => (
          <div class="stack-item">
            <h3>{step.phase}</h3>
            <p>{step.detail}</p>
          </div>
        ))}
      </div>
    </article>

    <article class="glass-card" id="analysis-design" data-reveal>
      <p class="section-eyebrow">Requirements analysis and design</p>
      <ul class="bullet-list">
        {capstone.analysisDesign.map((item) => <li>{item}</li>)}
      </ul>
    </article>

    <article class="glass-card" id="wireframes" data-reveal>
      <p class="section-eyebrow">Wireframes / mockups</p>
      <ul class="bullet-list">
        {capstone.wireframes.map((item) => <li>{item}</li>)}
      </ul>
    </article>

    <article class="glass-card" id="status-reports" data-reveal>
      <p class="section-eyebrow">Status reports</p>
      <ul class="bullet-list">
        {capstone.statusReports.map((item) => <li>{item}</li>)}
      </ul>
    </article>

    <article class="glass-card" id="implementation" data-reveal>
      <p class="section-eyebrow">System implementation</p>
      <ul class="bullet-list">
        {capstone.implementation.map((item) => <li>{item}</li>)}
      </ul>
    </article>
  </section>
</BaseLayout>
