---
import BaseLayout from '../components/layout/BaseLayout.astro';
import ProfessionalHighlights from '../components/sections/ProfessionalHighlights.astro';
import ExperienceTimeline from '../components/sections/ExperienceTimeline.astro';
import SectionHeading from '../components/sections/SectionHeading.astro';

const currentPath = Astro.url.pathname;
---
<BaseLayout
  currentPath={currentPath}
  title="Professional Summary | Henrique Custodio"
  description="Professional work samples, practical experience, and role history."
>
  <section class="section-shell shell page-hero">
    <SectionHeading
      eyebrow="Professional summary"
      title="Professional evidence and role history"
      intro="A direct professional-only view of the material grouped into the Work page."
    />
    <div class="toolbar-actions" data-reveal>
      <a class="button-secondary" href="/academic-projects/#professional">Open the integrated Work page</a>
    </div>
  </section>

  <ProfessionalHighlights />
  <ExperienceTimeline />
</BaseLayout>
